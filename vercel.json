{
    "devCommand": "uvicorn app:app --host 0.0.0.0 --port 8000",
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ],
    "excludefiles": [
        {
            "$schema": "https://openapi.vercel.sh/vercel.json",
            "functions": {
                "api/**/*.py": {
                    "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,fixtures/**,__fixtures__/**,testdata/**,sample-data/**,static/**,assets/**}"
                }
            }
        }
    ]
}